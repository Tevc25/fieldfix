# FieldFix — server-node environment variables
# Copy to .env and fill in values

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Database (absolute path; defaults to ./fieldfix.db next to dist/)
# DB_PATH=/absolute/path/to/fieldfix.db

# Admin token for PATCH /api/reports/:id/status
# Generate a strong random value for production
ADMIN_TOKEN=dev-admin-token-fieldfix

# VAPID keys for Web Push (generate once with: node -e "require('web-push').generateVAPIDKeys().then(console.log)")
# If not set, keys are generated on each startup (fine for dev, breaks push in prod)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:fieldfix@example.com
